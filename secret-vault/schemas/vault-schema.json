{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Secret Vault",
  "description": "Schema for the decrypted vault payload",
  "type": "object",
  "required": ["version", "secrets"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "secrets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["value", "created"],
        "properties": {
          "value": {
            "type": "string",
            "description": "The secret value"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Key-value tags as 'key:value' strings"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "rotated": {
            "type": ["string", "null"],
            "format": "date-time"
          }
        }
      }
    }
  }
}
